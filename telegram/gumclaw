#!/bin/bash
# GumClaw v2 — Telegram Bot Launcher for Claude Code
# Multi-bot registry, step-by-step launch, group permissions, back navigation.
# Powered by charmbracelet/gum for interactive UI.

set -euo pipefail

REGISTRY="$HOME/.claude/channels/telegram/bot-registry.json"
LOCKS_DIR="$HOME/.claude/channels/telegram/locks"
CHANNELS_DIR="$HOME/.claude/channels/telegram"
HAS_GUM=$(command -v gum &>/dev/null && echo "1" || echo "0")

# --- Theme: Bright Green ---
C_PRIMARY="#2FBF71"
C_ACCENT="#7DD3A5"
C_ERROR="#E23D2D"
C_MUTED="#8B7F77"

# ANSI fallbacks
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Launch state ---
SEL_BOT_ID=""
SEL_BOT_USERNAME=""
SEL_BOT_PURPOSE=""
SEL_BOT_TOKEN=""
SEL_DIR=""
SEL_GROUPS_COUNT=0

# ============================================================
# ASCII ART MASCOT
# ============================================================

show_banner() {
  if [[ "$HAS_GUM" == "1" ]]; then
    # Cat in green
    local cat_art
    cat_art=$(gum style --foreground "$C_PRIMARY" '   ╱|、' '  (  - -)' '  / つ つ' ' /  |  |')
    # Gumball in blue
    local ball
    ball=$(gum style --foreground "#4A9FD9" '' ' ◉ ' '' '')
    # Text in green
    local text_art
    text_art=$(gum style --foreground "$C_PRIMARY" '' '╔═╗╦ ╦╔╦╗╔═╗╦  ╔═╗╦ ╦' '║ ╦║ ║║║║║  ║  ╠═╣║║║' '╚═╝╚═╝╩ ╩╚═╝╩═╝╩ ╩╚╩╝')
    # Join horizontally
    gum join --horizontal "$cat_art" "$ball" "$text_art"
    echo ""
    gum style --foreground "$C_MUTED" "  Telegram Bot Launcher v2"
  else
    echo -e "${GREEN}"
    echo '   ╱|、        ╔═╗╦ ╦╔╦╗╔═╗╦  ╔═╗╦ ╦'
    echo '  (  - -)  ◉   ║ ╦║ ║║║║║  ║  ╠═╣║║║'
    echo '  / つ つ      ╚═╝╚═╝╩ ╩╚═╝╩═╝╩ ╩╚╩╝'
    echo ' /  |  |'
    echo -e "${NC}"
    echo -e "  ${DIM}Telegram Bot Launcher v2${NC}"
  fi
  echo ""
}

# ============================================================
# HELPERS
# ============================================================

ensure_registry() {
  mkdir -p "$LOCKS_DIR"
  chmod 700 "$LOCKS_DIR"
  if [[ ! -f "$REGISTRY" ]]; then
    echo '{"version":2,"bots":[]}' | jq '.' > "$REGISTRY"
    chmod 600 "$REGISTRY"
  fi
}

clean_stale_locks() {
  [[ -d "$LOCKS_DIR" ]] || return 0
  for lockfile in "$LOCKS_DIR"/*.lock; do
    [[ -f "$lockfile" ]] || continue
    local pid
    pid=$(jq -r '.pid' "$lockfile" 2>/dev/null)
    if [[ -n "$pid" ]] && ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$lockfile"
    fi
  done
}

is_bot_locked() {
  local bot_id="$1"
  local lockfile="$LOCKS_DIR/${bot_id}.lock"
  if [[ -f "$lockfile" ]]; then
    local pid
    pid=$(jq -r '.pid' "$lockfile" 2>/dev/null)
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      echo "$pid"
      return 0
    else
      rm -f "$lockfile"
    fi
  fi
  return 1
}

lock_bot() {
  local bot_id="$1"
  local cwd="$2"
  jq -n --arg pid "$$" --arg cwd "$cwd" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{pid: ($pid | tonumber), claimed_at: $ts, cwd: $cwd}' > "$LOCKS_DIR/${bot_id}.lock"
  chmod 600 "$LOCKS_DIR/${bot_id}.lock"
}

validate_token() {
  local token="$1"
  curl -s --max-time 5 "https://api.telegram.org/bot${token}/getMe" 2>/dev/null \
    | jq -r '.result.username // empty'
}

bot_count() {
  jq '.bots | length' "$REGISTRY"
}

get_bot_field() {
  local index="$1"
  local field="$2"
  jq -r ".bots[$index].$field" "$REGISTRY"
}

get_bot_by_id() {
  local id="$1"
  jq -r ".bots[] | select(.id == \"$id\")" "$REGISTRY"
}

gum_text() {
  # Styled text helper
  local color="${1:-$C_PRIMARY}"
  local text="$2"
  if [[ "$HAS_GUM" == "1" ]]; then
    gum style --foreground "$color" "$text"
  else
    echo "$text"
  fi
}

pipe() {
  # Print with pipe prefix
  echo "┃  $*"
}

pipe_empty() {
  echo "┃"
}

browse_directory() {
  local current="$HOME"
  while true; do
    local display_path
    display_path=$(echo "$current" | sed "s|^$HOME|~|")

    local dirs=()
    dirs+=("✓ USE THIS: $display_path")
    dirs+=("⬆ Go up")
    while IFS= read -r d; do
      [[ -n "$d" ]] && dirs+=("📁 $(basename "$d")")
    done < <(find "$current" -maxdepth 1 -type d -not -name '.*' -not -path "$current" 2>/dev/null | sort)
    dirs+=("✕ Cancel")

    local choice
    if [[ "$HAS_GUM" == "1" ]]; then
      choice=$(printf '%s\n' "${dirs[@]}" | gum choose --height 18 --header "  📂 $display_path" --cursor.foreground "$C_PRIMARY")
    else
      echo "  📂 $display_path"
      for i in "${!dirs[@]}"; do
        echo "  $((i + 1)). ${dirs[$i]}"
      done
      read -p "  Pick: " pick_num
      choice="${dirs[$((pick_num - 1))]}"
    fi

    if [[ "$choice" == "✓ USE THIS"* ]]; then
      echo "$current"
      return 0
    elif [[ "$choice" == "⬆ Go up" ]]; then
      local parent
      parent=$(dirname "$current")
      [[ "$parent" != "$current" ]] && current="$parent"
    elif [[ "$choice" == "✕ Cancel"* ]]; then
      echo ""
      return 0
    elif [[ "$choice" == "📁 "* ]]; then
      local dirname
      dirname=$(echo "$choice" | sed 's/^📁 //')
      current="$current/$dirname"
    else
      echo ""
      return 0
    fi
  done
}

detect_groups() {
  local token="$1"
  curl -s --max-time 5 "https://api.telegram.org/bot${token}/getUpdates" 2>/dev/null \
    | jq -c '[.result[] | select(.message.chat.type == "group" or .message.chat.type == "supergroup") | {id: (.message.chat.id | tostring), title: .message.chat.title}] | unique_by(.id)' 2>/dev/null || echo "[]"
}

# ============================================================
# PROGRESS DISPLAY
# ============================================================

show_progress() {
  local up_to="$1"
  pipe_empty
  if [[ "$up_to" -ge 2 ]] && [[ -n "$SEL_BOT_ID" ]]; then
    if [[ "$HAS_GUM" == "1" ]]; then
      pipe "$(gum style --foreground "$C_PRIMARY" '✓') Bot: @$SEL_BOT_USERNAME — $SEL_BOT_PURPOSE"
    else
      pipe "✓ Bot: @$SEL_BOT_USERNAME — $SEL_BOT_PURPOSE"
    fi
  fi
  if [[ "$up_to" -ge 3 ]] && [[ -n "$SEL_DIR" ]]; then
    local d
    d=$(echo "$SEL_DIR" | sed "s|^$HOME|~|")
    if [[ "$HAS_GUM" == "1" ]]; then
      pipe "$(gum style --foreground "$C_PRIMARY" '✓') Dir: $d"
    else
      pipe "✓ Dir: $d"
    fi
  fi
  if [[ "$up_to" -ge 4 ]]; then
    if [[ "$HAS_GUM" == "1" ]]; then
      pipe "$(gum style --foreground "$C_PRIMARY" '✓') Groups: $SEL_GROUPS_COUNT configured"
    else
      pipe "✓ Groups: $SEL_GROUPS_COUNT configured"
    fi
  fi
  pipe_empty
}

# ============================================================
# STEP 1: SELECT BOT
# ============================================================

step_bot() {
  local count
  count=$(bot_count)

  if [[ "$count" -eq 0 ]]; then
    pipe "No bots registered."
    pipe ""
    cmd_add
    return
  fi

  if [[ "$HAS_GUM" == "1" ]]; then
    pipe "$(gum style --foreground "$C_MUTED" '✦ Step 1 — Select Bot')"
  else
    pipe "✦ Step 1 — Select Bot"
  fi
  pipe_empty

  # Build options
  local options=()
  local ids=()
  local locked_ids=()

  for i in $(seq 0 $((count - 1))); do
    local id username purpose
    id=$(get_bot_field "$i" "id")
    username=$(get_bot_field "$i" "username")
    purpose=$(get_bot_field "$i" "purpose")

    local lock_pid
    if lock_pid=$(is_bot_locked "$id"); then
      options+=("⚠ $id  @$username  $purpose  [IN USE: PID $lock_pid]")
      locked_ids+=("$id")
    else
      options+=("● $id  @$username  $purpose")
    fi
    ids+=("$id")
  done
  options+=("✦ Register new bot...")

  # Pick
  local choice
  if [[ "$HAS_GUM" == "1" ]]; then
    choice=$(printf '%s\n' "${options[@]}" | gum choose --height $((count + 4)) --cursor.foreground "$C_PRIMARY" --selected.foreground "$C_PRIMARY")
  else
    for i in "${!options[@]}"; do
      pipe "$((i + 1)). ${options[$i]}"
    done
    pipe_empty
    read -p "┃  Pick: " pick_num
    if [[ "$pick_num" -gt "$count" ]] || [[ "$pick_num" -lt 1 ]]; then
      choice="✦ Register new bot..."
    else
      choice="${options[$((pick_num - 1))]}"
    fi
  fi

  if [[ "$choice" == *"Register new bot"* ]]; then
    cmd_add
    return
  fi

  # Extract bot id
  local selected_id
  selected_id=$(echo "$choice" | awk '{print $2}')

  # Check if locked
  if [[ ${#locked_ids[@]} -gt 0 ]]; then
    for lid in "${locked_ids[@]}"; do
      if [[ "$selected_id" == "$lid" ]]; then
        pipe_empty
        pipe "That bot is in use. Pick a different one."
        pipe "Release: gumclaw --release $selected_id"
        pipe_empty
        step_bot
        return
      fi
    done
  fi

  # Load bot data
  local bot
  bot=$(get_bot_by_id "$selected_id")
  SEL_BOT_ID="$selected_id"
  SEL_BOT_TOKEN=$(echo "$bot" | jq -r '.token')
  SEL_BOT_USERNAME=$(echo "$bot" | jq -r '.username')
  SEL_BOT_PURPOSE=$(echo "$bot" | jq -r '.purpose')
  SEL_DIR=$(echo "$bot" | jq -r '.project // empty')

  # Validate token
  local valid_user
  if [[ "$HAS_GUM" == "1" ]]; then
    valid_user=$(gum spin --spinner dot --title "  Validating @$SEL_BOT_USERNAME..." -- bash -c "
      result=\$(curl -s --max-time 5 'https://api.telegram.org/bot${SEL_BOT_TOKEN}/getMe')
      echo \"\$result\" | jq -r '.result.username // empty'
    ")
  else
    echo -n "┃  Validating... "
    valid_user=$(validate_token "$SEL_BOT_TOKEN") || true
  fi

  if [[ -z "$valid_user" ]]; then
    pipe "Token invalid for @$SEL_BOT_USERNAME"
    SEL_BOT_ID=""
    STEP_RESULT="back"
    return
  fi

  if [[ "$HAS_GUM" == "1" ]]; then
    pipe "$(gum style --foreground "$C_PRIMARY" '✓') @$SEL_BOT_USERNAME — $SEL_BOT_PURPOSE"
  else
    pipe "✓ @$SEL_BOT_USERNAME — $SEL_BOT_PURPOSE"
  fi
  pipe_empty

  # Edit purpose option
  local edit_choice
  if [[ "$HAS_GUM" == "1" ]]; then
    edit_choice=$(printf '%s\n' "Continue" "Edit purpose" | gum choose --cursor.foreground "$C_PRIMARY") || edit_choice="Continue"
  else
    read -p "┃  Edit purpose? [y/N] " ep
    edit_choice=$([[ "$ep" == "y" || "$ep" == "Y" ]] && echo "Edit purpose" || echo "Continue")
  fi

  if [[ "$edit_choice" == "Edit purpose" ]]; then
    local new_purpose
    if [[ "$HAS_GUM" == "1" ]]; then
      new_purpose=$(gum input --value "$SEL_BOT_PURPOSE" --width 50 --prompt "  Purpose: ")
    else
      read -p "┃  New purpose: " new_purpose
    fi
    if [[ -n "$new_purpose" ]] && [[ "$new_purpose" != "$SEL_BOT_PURPOSE" ]]; then
      SEL_BOT_PURPOSE="$new_purpose"
      jq --arg id "$SEL_BOT_ID" --arg p "$new_purpose" \
        '(.bots[] | select(.id == $id)).purpose = $p' \
        "$REGISTRY" > "${REGISTRY}.tmp"
      mv "${REGISTRY}.tmp" "$REGISTRY"
      chmod 600 "$REGISTRY"
      pipe "✓ Updated purpose"
    fi
  fi

  STEP_RESULT="next"
}

# ============================================================
# STEP 2: PROJECT DIRECTORY
# ============================================================

step_directory() {
  show_progress 2

  if [[ "$HAS_GUM" == "1" ]]; then
    pipe "$(gum style --foreground "$C_MUTED" '✦ Step 2 — Project Directory')"
  else
    pipe "✦ Step 2 — Project Directory"
  fi
  pipe_empty

  local dir_confirmed=false

  while [[ "$dir_confirmed" != "true" ]]; do
    if [[ -n "$SEL_DIR" ]] && [[ -d "$SEL_DIR" ]]; then
      local saved_display
      saved_display=$(echo "$SEL_DIR" | sed "s|^$HOME|~|")

      local dir_choice
      if [[ "$HAS_GUM" == "1" ]]; then
        dir_choice=$(printf '%s\n' \
          "Yes — use $saved_display" \
          "No — choose a different folder" \
          "⬅ Back to Step 1" \
          | gum choose --cursor.foreground "$C_PRIMARY")
      else
        pipe "Saved: $saved_display"
        read -p "┃  Use this? [Y/n/b(ack)] " di
        case "$di" in
          n|N) dir_choice="No" ;;
          b|B) dir_choice="⬅ Back" ;;
          *) dir_choice="Yes" ;;
        esac
      fi

      if [[ "$dir_choice" == "Yes"* ]]; then
        dir_confirmed=true
      elif [[ "$dir_choice" == *"Back"* ]]; then
        STEP_RESULT="back"
        return
      else
        local new_dir
        new_dir=$(browse_directory) || new_dir=""
        if [[ -n "$new_dir" ]] && [[ -d "$new_dir" ]]; then
          SEL_DIR="$new_dir"
          local confirm_display
          confirm_display=$(echo "$SEL_DIR" | sed "s|^$HOME|~|")
          if [[ "$HAS_GUM" == "1" ]]; then
            local cc
            cc=$(gum confirm "  Use: $confirm_display?" && echo "y" || echo "n")
            [[ "$cc" == "y" ]] && dir_confirmed=true
          else
            dir_confirmed=true
          fi
        fi
      fi
    else
      local dir_choice
      if [[ "$HAS_GUM" == "1" ]]; then
        dir_choice=$(printf '%s\n' \
          "📍 Stay here — $(pwd | sed "s|^$HOME|~|")" \
          "📂 Browse for a folder" \
          "⬅ Back to Step 1" \
          | gum choose --cursor.foreground "$C_PRIMARY")
      else
        read -p "┃  Directory [$(pwd)] or b(ack): " di
        case "$di" in
          b|B) dir_choice="⬅ Back" ;;
          "") dir_choice="📍 Stay" ;;
          *) dir_choice="📂 Browse" ;;
        esac
      fi

      if [[ "$dir_choice" == *"Stay"* ]]; then
        SEL_DIR="$(pwd)"
        dir_confirmed=true
      elif [[ "$dir_choice" == *"Back"* ]]; then
        STEP_RESULT="back"
        return
      else
        local new_dir
        new_dir=$(browse_directory) || new_dir=""
        if [[ -n "$new_dir" ]] && [[ -d "$new_dir" ]]; then
          SEL_DIR="$new_dir"
          dir_confirmed=true
        else
          SEL_DIR="$(pwd)"
          dir_confirmed=true
        fi
      fi
    fi
  done

  local display_dir
  display_dir=$(echo "$SEL_DIR" | sed "s|^$HOME|~|")
  if [[ "$HAS_GUM" == "1" ]]; then
    pipe "$(gum style --foreground "$C_PRIMARY" '✓') $display_dir"
  else
    pipe "✓ $display_dir"
  fi

  STEP_RESULT="next"
}

# ============================================================
# STEP 3: GROUPS & PERMISSIONS
# ============================================================

step_groups() {
  show_progress 3

  if [[ "$HAS_GUM" == "1" ]]; then
    pipe "$(gum style --foreground "$C_MUTED" '✦ Step 3 — Groups & Permissions')"
  else
    pipe "✦ Step 3 — Groups & Permissions"
  fi
  pipe_empty

  # Detect groups from Bot API
  local detected_json
  if [[ "$HAS_GUM" == "1" ]]; then
    detected_json=$(gum spin --spinner dot --title "  Scanning for groups..." -- bash -c "
      curl -s --max-time 5 'https://api.telegram.org/bot${SEL_BOT_TOKEN}/getUpdates' \
        | jq -c '[.result[] | select(.message.chat.type == \"group\" or .message.chat.type == \"supergroup\") | {id: (.message.chat.id | tostring), title: .message.chat.title}] | unique_by(.id)' 2>/dev/null || echo '[]'
    ")
  else
    detected_json=$(detect_groups "$SEL_BOT_TOKEN")
  fi
  detected_json="${detected_json:-[]}"

  # Load existing group config from registry
  local existing_groups
  existing_groups=$(jq -c --arg id "$SEL_BOT_ID" '(.bots[] | select(.id == $id)).groups // {}' "$REGISTRY" 2>/dev/null || echo "{}")

  local detected_count
  detected_count=$(echo "$detected_json" | jq 'length' 2>/dev/null || echo "0")

  local existing_count
  existing_count=$(echo "$existing_groups" | jq 'keys | length' 2>/dev/null || echo "0")

  SEL_GROUPS_COUNT=$existing_count

  # Show detected groups
  if [[ "$detected_count" -gt 0 ]]; then
    pipe "Detected groups:"
    echo "$detected_json" | jq -r '.[] | "┃    📋 \(.title) (\(.id))"' 2>/dev/null
    pipe_empty
  fi

  if [[ "$existing_count" -gt 0 ]]; then
    pipe "Configured groups: $existing_count"
    pipe_empty
  fi

  # Options
  local group_choice
  if [[ "$HAS_GUM" == "1" ]]; then
    group_choice=$(printf '%s\n' \
      "Continue (keep current)" \
      "Add/configure a group" \
      "⬅ Back to Step 2" \
      | gum choose --cursor.foreground "$C_PRIMARY")
  else
    read -p "┃  Continue/add group/b(ack)? [C/a/b] " gc
    case "$gc" in
      a|A) group_choice="Add/configure" ;;
      b|B) group_choice="⬅ Back" ;;
      *) group_choice="Continue" ;;
    esac
  fi

  if [[ "$group_choice" == *"Back"* ]]; then
    STEP_RESULT="back"
    return
  fi

  if [[ "$group_choice" == *"Add"* ]]; then
    # Build list of groups to configure
    local group_options=()

    # Add detected groups
    if [[ "$detected_count" -gt 0 ]]; then
      while IFS= read -r line; do
        group_options+=("$line")
      done < <(echo "$detected_json" | jq -r '.[] | "\(.title) (\(.id))"')
    fi
    group_options+=("Enter group ID manually")

    local group_pick
    if [[ "$HAS_GUM" == "1" ]]; then
      group_pick=$(printf '%s\n' "${group_options[@]}" | gum choose --cursor.foreground "$C_PRIMARY" --header "  Select group:")
    else
      for i in "${!group_options[@]}"; do
        pipe "$((i + 1)). ${group_options[$i]}"
      done
      read -p "┃  Pick: " gp_num
      group_pick="${group_options[$((gp_num - 1))]}"
    fi

    local group_id group_name
    if [[ "$group_pick" == "Enter group ID manually" ]]; then
      if [[ "$HAS_GUM" == "1" ]]; then
        group_id=$(gum input --placeholder "-1001234567890" --prompt "  Group ID: ")
        group_name=$(gum input --placeholder "My Team Chat" --prompt "  Group name: ")
      else
        read -p "┃  Group ID: " group_id
        read -p "┃  Group name: " group_name
      fi
    else
      group_id=$(echo "$group_pick" | grep -o '([^)]*)'  | tr -d '()')
      group_name=$(echo "$group_pick" | sed 's/ ([^)]*)$//')
    fi
    group_name="${group_name:-Group}"

    # requireMention
    local req_mention="true"
    if [[ "$HAS_GUM" == "1" ]]; then
      local mention_choice
      mention_choice=$(gum confirm "  Require @mention in group?" && echo "y" || echo "n")
      [[ "$mention_choice" == "n" ]] && req_mention="false"
    else
      read -p "┃  Require @mention? [Y/n] " rm
      [[ "$rm" == "n" || "$rm" == "N" ]] && req_mention="false"
    fi

    # allowFrom
    local allow_from="[]"
    if [[ "$HAS_GUM" == "1" ]]; then
      local restrict
      restrict=$(gum confirm "  Restrict to specific users?" && echo "y" || echo "n")
      if [[ "$restrict" == "y" ]]; then
        local user_ids
        user_ids=$(gum input --placeholder "123456,789012" --prompt "  User IDs (comma-separated): ")
        if [[ -n "$user_ids" ]]; then
          allow_from=$(echo "$user_ids" | tr ',' '\n' | jq -R . | jq -s .)
        fi
      fi
    else
      read -p "┃  Restrict to user IDs? (comma-separated, Enter for anyone): " user_ids
      if [[ -n "$user_ids" ]]; then
        allow_from=$(echo "$user_ids" | tr ',' '\n' | jq -R . | jq -s .)
      fi
    fi

    # Save to registry
    jq --arg bid "$SEL_BOT_ID" --arg gid "$group_id" --arg gname "$group_name" \
       --argjson mention "$req_mention" --argjson allow "$allow_from" \
      '(.bots[] | select(.id == $bid)).groups[$gid] = {name: $gname, requireMention: $mention, allowFrom: $allow}' \
      "$REGISTRY" > "${REGISTRY}.tmp" && mv "${REGISTRY}.tmp" "$REGISTRY"
    chmod 600 "$REGISTRY"

    SEL_GROUPS_COUNT=$((SEL_GROUPS_COUNT + 1))
    pipe "✓ Group added: $group_name"
    pipe_empty

    # Also write to trusted-users.json for auto-pair sync
    if [[ -f "$CHANNELS_DIR/trusted-users.json" ]]; then
      jq --arg gid "$group_id" --arg gname "$group_name" --argjson mention "$req_mention" --argjson allow "$allow_from" \
        'if .groups then .groups += [{"id": $gid, "name": $gname, "requireMention": $mention, "allowFrom": $allow}] | .groups |= unique_by(.id) else . + {"groups": [{"id": $gid, "name": $gname, "requireMention": $mention, "allowFrom": $allow}]} end' \
        "$CHANNELS_DIR/trusted-users.json" > "$CHANNELS_DIR/trusted-users.json.tmp"
      mv "$CHANNELS_DIR/trusted-users.json.tmp" "$CHANNELS_DIR/trusted-users.json"
    fi
  fi

  if [[ "$HAS_GUM" == "1" ]]; then
    pipe "$(gum style --foreground "$C_PRIMARY" '✓') Groups: $SEL_GROUPS_COUNT configured"
  else
    pipe "✓ Groups: $SEL_GROUPS_COUNT configured"
  fi

  STEP_RESULT="next"
}

# ============================================================
# STEP 4: LAUNCH
# ============================================================

step_launch() {
  show_progress 4

  # Run auto-pair
  bash "$CHANNELS_DIR/auto-pair.sh" 2>/dev/null || true

  # CD to directory
  if [[ -n "$SEL_DIR" ]] && [[ -d "$SEL_DIR" ]]; then
    cd "$SEL_DIR"
  fi

  # Write lock
  lock_bot "$SEL_BOT_ID" "${SEL_DIR:-$(pwd)}"

  local display_dir
  display_dir=$(echo "${SEL_DIR:-$(pwd)}" | sed "s|^$HOME|~|")

  if [[ "$HAS_GUM" == "1" ]]; then
    gum style \
      --foreground "$C_PRIMARY" \
      --border-foreground "$C_PRIMARY" \
      --border rounded \
      --padding "0 2" \
      --margin "0 2" \
      "🐾 Launching Claude Code" \
      "" \
      "  Bot:     @$SEL_BOT_USERNAME" \
      "  Purpose: $SEL_BOT_PURPOSE" \
      "  Dir:     $display_dir" \
      "  Groups:  $SEL_GROUPS_COUNT"
  else
    echo ""
    echo -e "  ${GREEN}🐾 Launching Claude Code${NC}"
    echo "    Bot:     @$SEL_BOT_USERNAME"
    echo "    Purpose: $SEL_BOT_PURPOSE"
    echo "    Dir:     $display_dir"
    echo "    Groups:  $SEL_GROUPS_COUNT"
  fi
  echo ""

  # Cleanup lock on exit
  trap "rm -f '$LOCKS_DIR/${SEL_BOT_ID}.lock'" EXIT INT TERM

  # Launch
  TELEGRAM_BOT_TOKEN="$SEL_BOT_TOKEN" exec claude \
    --dangerously-skip-permissions \
    --channels plugin:telegram@claude-plugins-official
}

# ============================================================
# ADD NEW BOT
# ============================================================

cmd_add() {
  if [[ "$HAS_GUM" == "1" ]]; then
    gum style --foreground "$C_ACCENT" "  ✦ New Bot Setup"
  else
    echo "  ✦ New Bot Setup"
  fi
  echo ""

  # Token
  local token
  echo "  Get a token from @BotFather on Telegram:"
  echo "    1. DM @BotFather"
  echo "    2. Send /newbot"
  echo "    3. Pick a name + username (must end in 'bot')"
  echo "    4. Copy the token"
  echo ""
  if [[ "$HAS_GUM" == "1" ]]; then
    token=$(gum input --placeholder "Paste bot token here" --width 60 --prompt "  Token: ")
  else
    read -p "  Token: " token
  fi

  if [[ -z "$token" ]]; then
    echo "  No token. Aborting."
    exit 1
  fi

  # Validate
  local username
  if [[ "$HAS_GUM" == "1" ]]; then
    username=$(gum spin --spinner dot --title "  Validating..." -- bash -c "
      curl -s --max-time 5 'https://api.telegram.org/bot${token}/getMe' | jq -r '.result.username // empty'
    ")
  else
    echo -n "  Validating... "
    username=$(validate_token "$token") || true
  fi

  if [[ -z "$username" ]]; then
    echo "  Invalid token."
    exit 1
  fi

  if [[ "$HAS_GUM" == "1" ]]; then
    echo "  $(gum style --foreground "$C_PRIMARY" '✓') Found: @$username"
  else
    echo "  ✓ Found: @$username"
  fi

  # Check duplicate
  if jq -e --arg u "$username" '.bots[] | select(.username == $u)' "$REGISTRY" &>/dev/null; then
    echo "  Already registered."
    exit 0
  fi

  # Purpose
  local purpose
  if [[ "$HAS_GUM" == "1" ]]; then
    purpose=$(gum input --placeholder "e.g., Marketing agent" --width 50 --prompt "  Purpose: ")
  else
    read -p "  Purpose: " purpose
  fi
  purpose="${purpose:-General assistant}"

  # ID
  local bot_id default_id
  default_id=$(echo "$username" | sed 's/_bot$//' | sed 's/[^a-zA-Z0-9_]/_/g')
  if [[ "$HAS_GUM" == "1" ]]; then
    bot_id=$(gum input --value "$default_id" --width 30 --prompt "  Short ID: ")
  else
    read -p "  Short ID [$default_id]: " bot_id
  fi
  bot_id="${bot_id:-$default_id}"

  # Directory
  local project=""
  echo ""
  if [[ "$HAS_GUM" == "1" ]]; then
    project=$(browse_directory) || project=""
  else
    read -p "  Project directory (Enter to skip): " project
  fi

  # Save
  local project_json
  [[ -n "$project" ]] && project_json="\"$project\"" || project_json="null"

  jq --arg id "$bot_id" --arg username "$username" --arg token "$token" \
     --arg purpose "$purpose" --argjson project "$project_json" --arg created "$(date +%Y-%m-%d)" \
    '.bots += [{"id": $id, "username": $username, "token": $token, "purpose": $purpose, "project": $project, "groups": {}, "created": $created}]' \
    "$REGISTRY" > "${REGISTRY}.tmp"
  mv "${REGISTRY}.tmp" "$REGISTRY"
  chmod 600 "$REGISTRY"

  echo ""
  if [[ "$HAS_GUM" == "1" ]]; then
    echo "  $(gum style --foreground "$C_PRIMARY" '✓') Registered: $bot_id (@$username)"
  else
    echo "  ✓ Registered: $bot_id (@$username)"
  fi

  # Connect now
  local connect
  if [[ "$HAS_GUM" == "1" ]]; then
    connect=$(gum confirm "  Connect now?" && echo "y" || echo "n")
  else
    read -p "  Connect now? [Y/n] " connect
    connect="${connect:-y}"
  fi

  if [[ "$connect" != "n" && "$connect" != "N" ]]; then
    SEL_BOT_ID="$bot_id"
    SEL_BOT_TOKEN="$token"
    SEL_BOT_USERNAME="$username"
    SEL_BOT_PURPOSE="$purpose"
    SEL_DIR="${project:-$(pwd)}"
    step_launch
  fi
}

# ============================================================
# LIST
# ============================================================

cmd_list() {
  ensure_registry
  clean_stale_locks
  show_banner

  local count
  count=$(bot_count)

  if [[ "$count" -eq 0 ]]; then
    echo "  No bots registered. Run: gumclaw --add"
    return
  fi

  if [[ "$HAS_GUM" == "1" ]]; then
    gum style --foreground "$C_MUTED" "  Registered bots:"
  else
    echo "  Registered bots:"
  fi
  echo ""

  for i in $(seq 0 $((count - 1))); do
    local id username purpose project
    id=$(get_bot_field "$i" "id")
    username=$(get_bot_field "$i" "username")
    purpose=$(get_bot_field "$i" "purpose")
    project=$(get_bot_field "$i" "project")

    local status_str=""
    local lock_pid
    if lock_pid=$(is_bot_locked "$id"); then
      status_str=" [IN USE: PID $lock_pid]"
    fi

    local proj_str=""
    if [[ "$project" != "null" ]] && [[ -n "$project" ]]; then
      proj_str="📁 $(echo "$project" | sed "s|^$HOME|~|")"
    fi

    if [[ -n "$status_str" ]]; then
      if [[ "$HAS_GUM" == "1" ]]; then
        echo "  $(gum style --foreground "$C_ERROR" '●') $id  @$username  $purpose$(gum style --foreground "$C_ERROR" "$status_str")"
      else
        echo -e "  ${RED}●${NC} $id  @$username  $purpose${RED}$status_str${NC}"
      fi
    else
      if [[ "$HAS_GUM" == "1" ]]; then
        echo "  $(gum style --foreground "$C_PRIMARY" '●') $id  @$username  $purpose"
      else
        echo -e "  ${GREEN}●${NC} $id  @$username  $purpose"
      fi
    fi
    if [[ -n "$proj_str" ]]; then
      if [[ "$HAS_GUM" == "1" ]]; then
        echo "    $(gum style --foreground "$C_MUTED" "$proj_str")"
      else
        echo -e "    ${DIM}$proj_str${NC}"
      fi
    fi
  done
  echo ""
}

# ============================================================
# INTERACTIVE PICKER (step machine)
# ============================================================

cmd_pick() {
  ensure_registry
  clean_stale_locks
  show_banner

  local current_step=1

  while true; do
    case $current_step in
      1)
        step_bot
        case "$STEP_RESULT" in
          next) current_step=2 ;;
          back) current_step=1 ;;
          *) ;; # stay (e.g., cmd_add was called)
        esac
        ;;
      2)
        step_directory
        case "$STEP_RESULT" in
          next) current_step=3 ;;
          back) current_step=1 ;;
        esac
        ;;
      3)
        step_groups
        case "$STEP_RESULT" in
          next) current_step=4 ;;
          back) current_step=2 ;;
        esac
        ;;
      4)
        step_launch
        break
        ;;
    esac
  done
}

# ============================================================
# MAIN
# ============================================================

ensure_registry

case "${1:-}" in
  --list|-l)
    cmd_list
    ;;
  --add|-a)
    show_banner
    cmd_add
    ;;
  --release|-r)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: gumclaw --release <bot-id>"
      exit 1
    fi
    lockfile="$LOCKS_DIR/${2}.lock"
    if [[ -f "$lockfile" ]]; then
      rm -f "$lockfile"
      echo "  Released: $2"
    else
      echo "  No lock for: $2"
    fi
    ;;
  --help|-h)
    show_banner
    echo "  Usage:"
    echo "    gumclaw                  Interactive bot picker + launch"
    echo "    gumclaw <bot-id>         Direct launch"
    echo "    gumclaw --list           Show all bots + status"
    echo "    gumclaw --add            Register new bot"
    echo "    gumclaw --release <id>   Force-release a lock"
    echo ""
    ;;
  "")
    cmd_pick
    ;;
  -*)
    echo "Unknown flag: $1"
    echo "Run: gumclaw --help"
    exit 1
    ;;
  *)
    # Direct launch by bot-id
    clean_stale_locks
    show_banner
    SEL_BOT_ID="$1"
    bot_data=$(get_bot_by_id "$1")
    if [[ -z "$bot_data" ]]; then
      echo "  Bot not found: $1"
      exit 1
    fi
    SEL_BOT_TOKEN=$(echo "$bot_data" | jq -r '.token')
    SEL_BOT_USERNAME=$(echo "$bot_data" | jq -r '.username')
    SEL_BOT_PURPOSE=$(echo "$bot_data" | jq -r '.purpose')
    SEL_DIR=$(echo "$bot_data" | jq -r '.project // empty')
    SEL_GROUPS_COUNT=$(echo "$bot_data" | jq '.groups // {} | keys | length')

    # Quick validate + launch
    valid_check=$(validate_token "$SEL_BOT_TOKEN")
    if [[ -z "$valid_check" ]]; then
      echo "  Token invalid for @$SEL_BOT_USERNAME"
      exit 1
    fi

    step_launch
    ;;
esac
